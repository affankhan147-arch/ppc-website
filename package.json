{
  "name": "ppc-lead-generation-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Config-driven Pay-Per-Call lead generation platform for emergency plumbing and drain cleaning in Dallas-Fort Worth.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "sites:build": "vinext build",
    "start": "next start",
    "test": "npm run test:routing && npm run test:status && npm run build && npm run test:production-pages",
    "typecheck": "tsc --noEmit",
    "test:routing": "node --test --experimental-strip-types tests/form-routing.test.mjs",
    "test:status": "node --test --experimental-strip-types tests/operational-status.test.mjs",
    "test:production-pages": "node --test tests/production-rendered-phone.test.mjs",
    "lint": "eslint src scripts worker --max-warnings=0",
    "qa": "node scripts/qa-check.mjs",
    "reports": "node scripts/generate-reports.mjs"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.10",
    "lucide-react": "latest",
    "next": "16.2.10",
    "next-sitemap": "latest",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@eslint/eslintrc": "3.3.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@tailwindcss/postcss": "4.1.13",
    "@types/node": "22.18.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "autoprefixer": "latest",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "postcss": "latest",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
