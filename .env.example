# ENVIRONMENT VARIABLE TEMPLATE
# Do not put real keys in GitHub.
# Put real keys only in your local user environment, Colab Secrets, GitHub Secrets, or Vercel Environment Variables.

# Optional local/automation tokens. Keep blank in GitHub.
OPENAI_API_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=

# Analytics placeholders. Add these in Vercel only after owner approval.
GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=

# Verification and indexing placeholders. Keep blank until DNS and HTTPS are active.
NEXT_PUBLIC_SEARCH_CONSOLE_TOKEN=
NEXT_PUBLIC_BING_WEBMASTER_TOKEN=
INDEXNOW_KEY=

# Vercel production domain values.
SITE_DOMAIN=plumbinghands.com
NEXT_PUBLIC_SITE_URL=https://plumbinghands.com

# Placeholder call-tracking values. Replace in Vercel before public launch.
NEXT_PUBLIC_TRACKED_PHONE_DISPLAY=(469) 555-0188
NEXT_PUBLIC_TRACKED_PHONE_E164=+14695550188
NEXT_PUBLIC_FALLBACK_PHONE_DISPLAY=(469) 555-0188
NEXT_PUBLIC_FALLBACK_PHONE_E164=+14695550188
